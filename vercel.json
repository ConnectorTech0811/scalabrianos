{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "index.js"
    }
  },
  "rewrites": [
    {
      "source": "/api(/.*)?",
      "destination": "backend"
    },
    {
      "source": "/uploads(/.*)?",
      "destination": "backend"
    },
    {
      "source": "/assets/(.*)",
      "destination": "frontend/assets/$1"
    },
    {
      "source": "/(.*\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|json|woff|woff2|ttf|eot|webp))",
      "destination": "frontend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/index.html"
    }
  ]
}
